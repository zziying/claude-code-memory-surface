# === Memory MCP Server ===
MCP_TOKEN=your_random_token_here
GEMINI_API_KEY=your_gemini_api_key_here
MEMORY_DB_PATH=./memories.db
MEMORY_MCP_PORT=3458

# === Hook（hook/memory_surface.py 用） ===
# 你的 memory MCP server 地址，需要带 token
#   本机: http://localhost:3458/<MCP_TOKEN>
#   远程: https://your.domain/memory-mcp/<MCP_TOKEN>
MEMORY_MCP_URL=
HOOK_TIMEOUT_S=1.5
HOOK_SCORE_THRESHOLD=0.7
HOOK_MAX_CHUNKS=2
HOOK_MIN_LEN_TRIGGER=6
