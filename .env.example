# === Memory MCP Server config ===
# Random 32-char hex token; clients (incl. Claude Code MCP entry) must include this in URL path
MCP_TOKEN=your_random_token_here_change_me

# Get a free Gemini API key from https://aistudio.google.com/apikey
# Free tier rate limit (~75 RPM observed) is enough for personal use
GEMINI_API_KEY=your_gemini_api_key_here

# Embedding model — gemini-embedding-001 returns 3072-dim vectors
EMBED_MODEL=gemini-embedding-001

# Where the SQLite db lives (relative or absolute)
MEMORY_DB_PATH=./memories.db

# Port for the MCP server to listen on
MEMORY_MCP_PORT=3458


# === Hook script config (used by hook/memory_surface.py) ===
# Full URL to your memory MCP server (include the token in the path)
# Examples:
#   http://localhost:3458/<MCP_TOKEN>          (running on same machine)
#   https://your.domain/memory-mcp/<MCP_TOKEN> (behind nginx reverse proxy)
MEMORY_MCP_URL=

# Hook tunables (defaults shown)
HOOK_TIMEOUT_S=1.5
HOOK_SCORE_THRESHOLD=0.7
HOOK_MAX_CHUNKS=2
HOOK_MIN_LEN_TRIGGER=6
